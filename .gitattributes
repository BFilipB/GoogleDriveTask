# Auto detect text files and normalize line endings to LF
* text=auto

# C# files
*.cs text eol=lf

# Project files
*.csproj text eol=lf
*.sln text eol=lf
*.json text eol=lf

# Documentation
*.md text eol=lf
LICENSE text eol=lf
.gitignore text eol=lf

# Binary files
*.exe binary
*.dll binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
